tmp_extract/*

# Work products are durable evidence packages. Keep normal docs/tables/figures
# visible, but hide raw reconstructed solver payloads and large row dumps.
work_products/**
!work_products/.gitkeep
!work_products/**/
!work_products/**/*.md
!work_products/**/*.json
!work_products/**/*.csv
!work_products/**/*.svg
!work_products/**/*.png
!work_products/**/*.pdf
!work_products/**/*.txt
!work_products/**/*.yaml
!work_products/**/*.yml
!work_products/**/*.pptx
work_products/**/.pytest_cache/
work_products/**/*.pyc
work_products/**/*.vtk
work_products/**/*.ogv
work_products/**/*.stl
# Duplicated/generated figure exports can be regenerated; keep source SVG/PNG
